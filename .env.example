# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Authentication (NextAuth.js) ────────────────────────────────────
# Generate with: openssl rand -base64 32  OR  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# REQUIRED — app will throw on startup if missing
NEXTAUTH_SECRET=change_me_generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# ── Database ────────────────────────────────────────────────────────
# Use your Cloud MySQL or PostgreSQL connection string (Aiven, Supabase, etc.)
DATABASE_URL=mysql://user:password@host:port/database

# ── Payment (Bangladesh — Manual Send Money) ─────────────────────────
# Customers send money to these numbers and submit their transaction ID.
# Admin verifies manually in the dashboard.
BKASH_NUMBER=01XXXXXXXXX
NAGAD_NUMBER=01XXXXXXXXX
COD_ENABLED=true

# ── Image Uploads (Cloudinary) ───────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email (Resend) ───────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# ── App ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
