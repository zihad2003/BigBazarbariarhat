# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Authentication (NextAuth.js) ────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change_me_generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# ── Database ────────────────────────────────────────────────────────
# Swap the adapter in apps/web/src/lib/db/index.ts, then set the URL here.
# MySQL / PlanetScale / TiDB:
DATABASE_URL=mysql://user:password@localhost:3306/bigbazar_db
# PostgreSQL / Supabase / Neon:
# DATABASE_URL=postgresql://user:password@localhost:5432/bigbazar_db

# ── Payment Gateways (Bangladesh) ───────────────────────────────────
BKASH_USERNAME=your_merchant_username
BKASH_PASSWORD=your_merchant_password
BKASH_API_KEY=your_app_key
BKASH_SECRET_KEY=your_app_secret

NAGAD_MERCHANT_NUMBER=01XXXXXXXXX

# ── Image Uploads (Cloudinary) ───────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email (Resend) ───────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# ── App ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
